##############################################################################
# MODELS
##############################################################################
def make_ocr():
    if OCR_PROFILE == "gpu_locked":
        # Locked profile for PaddleOCR 3.x on WSL GPU.
        try:
            sig = inspect.signature(PaddleOCR.__init__)
            params = sig.parameters
            kwargs = {"lang": "en"}

            if "text_det_limit_side_len" in params:
                kwargs["text_det_limit_side_len"] = 4000
            elif "det_limit_side_len" in params:
                kwargs["det_limit_side_len"] = 4000

            if "use_textline_orientation" in params:
                kwargs["use_textline_orientation"] = True
            elif "use_angle_cls" in params:
                kwargs["use_angle_cls"] = True

            if "device" in params:
                kwargs["device"] = "gpu:0"
            elif "use_gpu" in params:
                kwargs["use_gpu"] = True

            return PaddleOCR(**kwargs)
        except Exception as e:
            print(f"OCR gpu_locked init failed, fallback to auto profile: {e}")

    try:
        sig = inspect.signature(PaddleOCR.__init__)
        params = sig.parameters
        kwargs = {"lang": "en"}
        if "text_det_limit_side_len" in params:
            kwargs["text_det_limit_side_len"] = 4000
        elif "det_limit_side_len" in params:
            kwargs["det_limit_side_len"] = 4000
        if "device" in params:
            kwargs["device"] = "gpu:0"
        elif "use_gpu" in params:
            kwargs["use_gpu"] = True
        return PaddleOCR(**kwargs)
    except Exception as e:
        print(f"OCR GPU init failed, fallback to CPU: {e}")
        sig = inspect.signature(PaddleOCR.__init__)
        params = sig.parameters
        kwargs = {"lang": "en"}
        if "text_det_limit_side_len" in params:
            kwargs["text_det_limit_side_len"] = 4000
        elif "det_limit_side_len" in params:
            kwargs["det_limit_side_len"] = 4000
        if "device" in params:
            kwargs["device"] = "cpu"
        elif "use_gpu" in params:
            kwargs["use_gpu"] = False
        return PaddleOCR(**kwargs)

ocr = make_ocr()

