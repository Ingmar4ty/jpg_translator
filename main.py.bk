##############################################################################
# CACHE
##############################################################################
if os.path.exists(CACHE_FILE):
    with open(CACHE_FILE, "r", encoding="utf8") as f:
        TRANSLATION_CACHE = json.load(f)
else:
    TRANSLATION_CACHE = {}

def save_cache():
    with open(CACHE_FILE, "w", encoding="utf8") as f:
        json.dump(TRANSLATION_CACHE, f, ensure_ascii=False, indent=2)

def append_debug(debug, stage, **data):
    debug.setdefault("events", []).append({
        "timestamp": datetime.now().isoformat(timespec="seconds"),
        "stage": stage,
        "data": data,
    })

def write_debug_log(debug):
    safe_name = re.sub(r"[^A-Za-z0-9_.-]+", "_", debug.get("file_name", "unknown"))
    stamp = datetime.now().strftime("%Y%m%d_%H%M%S_%f")
    log_path = Path(LOGS_DIR) / f"{safe_name}+{stamp}.json"
    with open(log_path, "w", encoding="utf8") as f:
        json.dump(debug, f, ensure_ascii=False, indent=2)
    return log_path

def save_outputs(img, input_path):
    out_path = Path(OUTPUT_DIR) / input_path.relative_to(INPUT_DIR)
    out_path.parent.mkdir(parents=True, exist_ok=True)
    cv2.imwrite(str(out_path), img)

    ready_dir = Path(READY_OUTPUT_DIR)
    ready_dir.mkdir(parents=True, exist_ok=True)
    dt = datetime.now().strftime("%Y%m%d_%H%M%S")
    ready_name = f"{input_path.stem}+{dt}+.jpg"
    ready_path = ready_dir / ready_name
    cv2.imwrite(str(ready_path), img)
    return out_path, ready_path

def is_suspicious_text(text):
    t = (text or "").strip()
    if len(t) < 2:
        return True
    # OCR trash usually has lots of punctuation/random symbols.
    alnum = sum(1 for c in t if c.isalnum())
    punct_chars = "!\"#$%&'()*+,-./:;<=>?@[\\]^_`{|}~"
    punct = sum(1 for c in t if c in punct_chars)
    digits = sum(1 for c in t if c.isdigit())
    unique_punct = len({c for c in t if c in punct_chars})
    if alnum == 0:
        return True
    if punct / len(t) > 0.30:
        return True
    if alnum / len(t) < 0.4:
        return True
    if len(t) >= 8 and digits >= 2 and unique_punct >= 3:
        return True
    return False

def has_cyrillic(text):
    return bool(re.search(r"[А-Яа-яЁё]", text or ""))

def has_latin(text):
    return bool(re.search(r"[A-Za-z]", text or ""))

def is_bad_cached_translation(src, tr):
    s = (src or "").strip()
    t = (tr or "").strip()
    norm = lambda x: re.sub(r"\s+", " ", (x or "").strip().lower())
    if not t:
        return True
    if norm(s) == norm(t):
        return True
    # Mixed output like "Faulty return пружина" should be retranslated.
    if has_cyrillic(t) and has_latin(t):
        return True
    # For English source, translation should usually contain Cyrillic.
    if has_latin(s) and not has_cyrillic(t):
        return True
    return False

def is_proper_name_text(text):
    t = (text or "").strip()
    if not t:
        return False
    known = ["HONDA", "VT250", "VT250F", "VT250-FII", "SUZUKI", "YAMAHA", "KAWASAKI"]
    upper = t.upper()
    if any(x in upper for x in known):
        return True
    # Mostly model/title tokens: uppercase + digits/hyphen only.
    if re.fullmatch(r"[A-Z0-9\-\s]{3,}", upper):
        return True
    return False

def sanitize_cache(cache):
    cleaned = {}
    dropped = 0
    for k, v in cache.items():
        if is_suspicious_text(k) or is_suspicious_text(v):
            dropped += 1
            continue
        if FORCE_RETRANSLATE_BAD_CACHE and is_bad_cached_translation(k, v):
            dropped += 1
            continue
        cleaned[k] = v
    if dropped:
        print(f"Removed {dropped} suspicious cache entries")
    return cleaned, dropped

TRANSLATION_CACHE, _cache_dropped = sanitize_cache(TRANSLATION_CACHE)
if _cache_dropped:
    save_cache()

